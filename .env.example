# eOzka System Environment Variables (Example)
# Copy this file to .env.local and populate with your own live tokens.

# ── DISCORD INTEGRATION ──
# Main landing page contact webhook
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/YOUR_CHANNEL_ID/YOUR_TOKEN
# Campus Ambassador cohort submissions webhook
DISCORD_AMBASSADOR_WEBHOOK_URL=https://discord.com/api/webhooks/YOUR_CHANNEL_ID/YOUR_TOKEN
# Client meetup / consultation request webhook
DISCORD_MEETUP_WEBHOOK_URL=https://discord.com/api/webhooks/YOUR_CHANNEL_ID/YOUR_TOKEN

# ── TELEGRAM BOT INTEGRATION ──
# Set these to route contact submissions to a Telegram chat/channel
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_CHAT_ID=your_telegram_chat_or_channel_id

# ── RESEND EMAIL INTEGRATION ──
# Set this to route HTML mail notifications to eozka.hq@gmail.com
RESEND_API_KEY=re_your_resend_api_key
